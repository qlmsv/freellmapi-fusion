# Copy to .env.fusion and fill in. fusion_bot.py auto-loads .env.fusion.
# NOTE: these are the FUSION layer vars — separate from ~/freellmapi/.env (the gateway).

# --- upstream gateway (FreeLLMAPI) ---
UPSTREAM_BASE_URL=https://freellmapi-rf2v.onrender.com/v1
UPSTREAM_API_KEY=                # FreeLLMAPI "unified key" from the dashboard — SECRET

# --- fusion model config ---
PANEL_MODELS=qwen/qwen3-32b,gemma4:31b,@cf/nvidia/nemotron-3-120b-a12b,deepseek-ai/deepseek-v4-flash
JUDGE_MODEL=@cf/moonshotai/kimi-k2.6,@cf/zai-org/glm-4.7-flash,meta-llama/llama-3.3-70b-instruct:free

# --- fusion endpoint auth (clients send this) ---
FUSION_API_KEY=                  # generate a random secret, e.g. `openssl rand -hex 24`

# --- telegram (optional) ---
TELEGRAM_TOKEN=                  # from @BotFather; leave empty to disable the bot
ALLOWED_USER_IDS=                # comma/space separated numeric ids; empty = allow anyone

# --- tunables ---
MAX_CONCURRENCY=4
REQUEST_TIMEOUT=120
PORT=8000
